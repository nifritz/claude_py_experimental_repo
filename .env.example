# =============================================================================
# Copia questo file in .env e compila i valori reali
# NON committare .env
# =============================================================================

# --- Claude Code ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Webhook deploy automatico ---
DEPLOY_SECRET=scegli_una_stringa_segreta_lunga

# --- Workspace montato in Claude Code ---
WORKSPACE_PATH=/opt/projects   # cartella progetti sull'host

# --- Google OAuth2 (python-utils) ---
GDRIVE_CREDENTIALS_FILE=credentials.json
GDRIVE_TOKEN_FILE=token.json

# --- MariaDB ---
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=n8n
MYSQL_USER=n8n
MYSQL_PASSWORD=changeme_n8n

# --- N8N ---
N8N_ENCRYPTION_KEY=changeme_32chars_random_string
N8N_WEBHOOK_URL=https://your-domain.com:5678
